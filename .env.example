# Copy to .env.local for local development. .env.local is gitignored.

# ── Database ─────────────────────────────────────────────────────────────────
# Auth DB connection string. Local dev usually points at the local Postgres
# running the gcp-universal-backend schema. Cloud Run deploys inject this via
# Secret Manager (dev-gub-admin-db-url; see cloudbuild/dev.yaml).
DATABASE_URL=postgresql://gub_dev:change_me@localhost:5432/gub_dev

# ── GUB backend URL (server-side + client-side) ──────────────────────────────
# Used by every /api/* proxy route to call the GCP universal backend.
# In production, set via cloudbuild to the deployed backend URL.
GUB_BACKEND_URL=http://localhost:3000
# Public fallback (frontend SDK reads this when GUB_BACKEND_URL isn't set).
NEXT_PUBLIC_GUB_URL=http://localhost:3000

# ── IAP dev-email bypass (local development ONLY) ────────────────────────────
# When set AND NODE_ENV=development AND the request Host is localhost, this
# shortcuts past Cloud IAP and authenticates the request as this email.
# The startup guard in src/lib/iap-dev-bypass.ts refuses to boot if this
# var is set but NODE_ENV is anything other than 'development' — NEVER set
# this on a deployed Cloud Run service.
IAP_DEV_EMAIL=you@yourdomain.com

# ── Node environment (set by Next automatically — rarely need to override) ───
# `next dev` sets NODE_ENV=development; `next build && next start` uses
# production. Deployed Cloud Run services set NODE_ENV=production explicitly
# (see cloudbuild/dev.yaml) so the IAP guard above stays armed.
# NODE_ENV=development
