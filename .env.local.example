# Copy to .env.local for local development

# gub-admin connects as gub_admin role (BYPASSRLS) — full row access, no RLS filtering.
# Protected at the network layer by GCP IAP. Never expose this credential outside IAP.
# Production: postgresql://gub_admin:<password>@<host>:5432/gub?sslmode=require
DATABASE_URL=postgresql://gub_admin:change_me_admin@localhost:5432/gub

# Local dev IAP bypass — set to your email to skip the IAP header check
IAP_DEV_EMAIL=you@yourdomain.com
