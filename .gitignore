# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# secrets — code-level coverage for anything that should NOT hit git
.env
.env.*
!.env.example
secrets/
keys/
*.pem
*.key
*.p12
*-sa.json
*service-account*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files — (kept for clarity; covered by the secrets block above)
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
